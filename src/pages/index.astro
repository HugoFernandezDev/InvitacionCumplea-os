    <!-- GSAP & Animations Script -->
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // --- LENIS SMOOTH SCROLL ---
      const lenis = new (window as any).Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        smoothTouch: false,
      });

      // Lock Lenis scroll on first load because envelope is active
      lenis.stop();

      // Synchronize ScrollTrigger with Lenis
      lenis.on('scroll', ScrollTrigger.update);

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);

      // --- CUSTOM CURSOR ---
      const cursor = document.getElementById('custom-cursor');
      const cursorDot = document.getElementById('custom-cursor-dot');
      let mouseX = window.innerWidth / 2;
      let mouseY = window.innerHeight / 2;

      if (cursor && cursorDot) {
        gsap.set(cursor, { xPercent: -50, yPercent: -50, x: mouseX, y: mouseY });
        gsap.set(cursorDot, { xPercent: -50, yPercent: -50, x: mouseX, y: mouseY });

        const xTo = gsap.quickTo(cursor, "x", { duration: 0.35, ease: "power3.out" });
        const yTo = gsap.quickTo(cursor, "y", { duration: 0.35, ease: "power3.out" });
        const dotXTo = gsap.quickTo(cursorDot, "x", { duration: 0.1, ease: "power3.out" });
        const dotYTo = gsap.quickTo(cursorDot, "y", { duration: 0.1, ease: "power3.out" });

        window.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          xTo(e.clientX);
          yTo(e.clientY);
          dotXTo(e.clientX);
          dotYTo(e.clientY);
        });
      }

      const registerHoverEvents = () => {
        const interactiveTargets = document.querySelectorAll(
          'a, button, .timeline-header, .dresscode-tab, input, select, .gallery-card, #rsvp-custom-toggle'
        );
        interactiveTargets.forEach(el => {
          el.addEventListener('mouseenter', () => {
            gsap.to(cursor, { scale: 1.8, borderColor: '#c5a059', backgroundColor: 'rgba(197, 160, 89, 0.1)', duration: 0.3 });
            gsap.to(cursorDot, { scale: 0, duration: 0.2 });
          });
          el.addEventListener('mouseleave', () => {
            gsap.to(cursor, { scale: 1, borderColor: '#c5a059', backgroundColor: 'transparent', duration: 0.3 });
            gsap.to(cursorDot, { scale: 1, duration: 0.2 });
          });
        });
      };
      registerHoverEvents();

      // Make custom cursor hide when inside Google Maps iframe to allow perfect native dragging
      const mapWrapper = document.querySelector('.map-wrapper');
      if (mapWrapper) {
        mapWrapper.addEventListener('mouseenter', () => {
          gsap.to([cursor, cursorDot], { opacity: 0, scale: 0, duration: 0.2 });
        });
        mapWrapper.addEventListener('mouseleave', () => {
          gsap.to([cursor, cursorDot], { opacity: 1, scale: 1, duration: 0.2 });
        });
      }

      // --- HIGH PERFORMANCE CANVAS PARTICLE SYSTEM ---
      const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
      if (canvas) {
        const ctx = canvas.getContext('2d');
        let particles: any[] = [];
        const particleCount = 45;

        const resizeCanvas = () => {
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
        };
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        class GoldDustParticle {
          x: number;
          y: number;
          size: number;
          speedX: number;
          speedY: number;
          opacity: number;
          fadeSpeed: number;

          constructor() {
            this.x = Math.random() * canvas.width;
            this.y = Math.random() * canvas.height;
            this.size = Math.random() * 2 + 0.8;
            this.speedX = Math.random() * 0.4 - 0.2;
            this.speedY = -(Math.random() * 0.5 + 0.2);
            this.opacity = Math.random() * 0.5 + 0.1;
            this.fadeSpeed = Math.random() * 0.002 + 0.0005;
          }

          update() {
            this.x += this.speedX;
            this.y += this.speedY;

            // Handle hover wind turbulence
            const dx = mouseX - this.x;
            const dy = mouseY - this.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 150) {
              const force = (150 - dist) / 150;
              this.x -= (dx / dist) * force * 0.8;
              this.y -= (dy / dist) * force * 0.8;
            }

            // Recycle if particle goes offscreen or fades out
            if (this.y < 0 || this.x < 0 || this.x > canvas.width) {
              this.y = canvas.height + 10;
              this.x = Math.random() * canvas.width;
              this.opacity = Math.random() * 0.5 + 0.1;
            }
          }

          draw() {
            if (!ctx) return;
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(197, 160, 89, ${this.opacity})`;
            ctx.shadowBlur = 4;
            ctx.shadowColor = '#c5a059';
            ctx.fill();
          }
        }

        // Initialize particles
        for (let i = 0; i < particleCount; i++) {
          particles.push(new GoldDustParticle());
        }

        // Burst function for interactive events (e.g. music suggest, RSVP success)
        (window as any).triggerGoldBurst = (originX: number, originY: number) => {
          for (let i = 0; i < 35; i++) {
            const p = new GoldDustParticle();
            p.x = originX;
            p.y = originY;
            const angle = Math.random() * Math.PI * 2;
            const speed = Math.random() * 5 + 2;
            p.speedX = Math.cos(angle) * speed;
            p.speedY = Math.sin(angle) * speed;
            p.opacity = 1.0;
            p.size = Math.random() * 3 + 1.2;
            p.fadeSpeed = Math.random() * 0.02 + 0.01;
            particles.push(p);

            // Cap absolute particle length to prevent lag
            if (particles.length > 150) {
              particles.shift();
            }
          }
        };

        const animateParticles = () => {
          if (!ctx) return;
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.shadowBlur = 0; // reset
          
          particles.forEach((p, idx) => {
            p.update();
            p.draw();
            
            // For burst particles, fade them out permanently
            if (p.fadeSpeed > 0.003) {
              p.opacity -= p.fadeSpeed;
              if (p.opacity <= 0) {
                particles.splice(idx, 1);
              }
            }
          });

          // Maintain base particle pool
          while (particles.length < particleCount) {
            particles.push(new GoldDustParticle());
          }

          requestAnimationFrame(animateParticles);
        };
