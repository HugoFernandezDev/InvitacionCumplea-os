        gsap.to(modalContent, { scale: 0.9, duration: 0.3, ease: 'power2.in' });
      };

      openModalBtn?.addEventListener('click', openModal);
      closeModalBtn?.addEventListener('click', closeModal);
      
      modal?.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });

      // --- CUSTOM RSVP TOGGLE LOGIC ---
      const toggle = document.getElementById('rsvp-custom-toggle');
      const activeBg = document.getElementById('toggle-active-bg');
      const opts = document.querySelectorAll('.rsvp-toggle-opt');
      const hiddenInput = document.getElementById('attendance-hidden-input');
      const extraFields = document.getElementById('extra-fields-container');
      const decliningMessage = document.getElementById('declining-message-container');
      const submitBtn = document.getElementById('rsvp-submit-btn');

      if (toggle && activeBg && hiddenInput && extraFields && decliningMessage && submitBtn) {
        opts.forEach((opt) => {
          opt.addEventListener('click', () => {
            const val = opt.getAttribute('data-value');
            hiddenInput.value = val;
            
            if (val === 'yes') {
              gsap.to(activeBg, { x: 0, duration: 0.5, ease: 'back.out(1.3)' });
              gsap.to(opts[0], { color: '#0a0a0a', duration: 0.3 });
              gsap.to(opts[1], { color: '#d4d4d8', duration: 0.3 });
              
              gsap.to(decliningMessage, { height: 0, opacity: 0, marginTop: 0, duration: 0.4, ease: 'power3.inOut' });
              gsap.to(extraFields, { height: 'auto', opacity: 1, marginTop: 24, duration: 0.5, ease: 'power3.out' });
              submitBtn.innerText = 'Confirmar Mi Lugar';
            } else {
              const shift = toggle.clientWidth / 2 - 4;
              gsap.to(activeBg, { x: shift, duration: 0.5, ease: 'back.out(1.3)' });
              gsap.to(opts[0], { color: '#d4d4d8', duration: 0.3 });
              gsap.to(opts[1], { color: '#0a0a0a', duration: 0.3 });
              
              gsap.to(extraFields, { height: 0, opacity: 0, marginTop: 0, duration: 0.4, ease: 'power3.inOut' });
              gsap.to(decliningMessage, { height: 'auto', opacity: 1, marginTop: 24, duration: 0.5, ease: 'power3.out' });
              submitBtn.innerText = 'Enviar Mis Buenos Deseos';
            }
          });
        });

        toggle.addEventListener('mouseenter', () => {
          gsap.to(cursor, { scale: 1.8, borderColor: '#c5a059', backgroundColor: 'rgba(197, 160, 89, 0.1)', duration: 0.3 });
          gsap.to(cursorDot, { scale: 0, duration: 0.2 });
        });
        toggle.addEventListener('mouseleave', () => {
          gsap.to(cursor, { scale: 1, borderColor: '#c5a059', backgroundColor: 'transparent', duration: 0.3 });
          gsap.to(cursorDot, { scale: 1, duration: 0.2 });
        });
      }

      const successScreen = document.getElementById('rsvp-success-screen');
      const successTitle = document.getElementById('success-title');
      const successMessage = document.getElementById('success-message');
      const successCloseBtn = document.getElementById('success-close-btn');

      // --- WAX SPARKLE CONFETTI BURST ---
      const triggerCelebration = () => {
        if (!modalContent) return;
        const rect = modalContent.getBoundingClientRect();
        
        // Use high-performance canvas burst
        if ((window as any).triggerGoldBurst) {
          (window as any).triggerGoldBurst(rect.width / 2, rect.height / 2);
        }
      };

      rsvpForm?.addEventListener('submit', (e) => {
        e.preventDefault();
        
        if (successScreen && successTitle && successMessage && hiddenInput) {
          const isAttending = hiddenInput.value === 'yes';
          
          if (isAttending) {
            const text = "¡Te espero con gusto!";
            successTitle.innerHTML = text.split('').map(char => {
              if (char === ' ') return `<span class="inline-block" style="width: 0.25em;">&nbsp;</span>`;
              return `<span class="success-char inline-block transform-gpu opacity-0 select-none" style="perspective: 400px; display: inline-block;">${char}</span>`;
            }).join('');

            successMessage.innerText = 'Tu lugar ha sido reservado con éxito. Estoy muy feliz de poder celebrar este cumpleaños contigo. ¡Nos vemos el 25 de Diciembre!';
            triggerCelebration();
          } else {
            const text = "¡Gracias por tu cariño!";
            successTitle.innerHTML = text.split('').map(char => {
              if (char === ' ') return `<span class="inline-block" style="width: 0.25em;">&nbsp;</span>`;
              return `<span class="success-char inline-block transform-gpu opacity-0 select-none" style="display: inline-block;">${char}</span>`;
            }).join('');

            successMessage.innerText = 'Lamento mucho que no puedas asistir, pero me alegra inmensamente saber que estarás brindando conmigo a la distancia. ¡Un abrazo fuerte!';
          }

          successScreen.classList.remove('pointer-events-none');
          gsap.fromTo(successScreen, 
            { opacity: 0, scale: 0.95 },
            { opacity: 1, scale: 1, duration: 0.6, ease: 'power3.out' }
          );

          if (isAttending) {
            gsap.fromTo('.success-char', 
              { opacity: 0, y: 60, scale: 0.2, rotateX: -100, rotateY: 45, filter: 'blur(8px)' },
              { opacity: 1, y: 0, scale: 1, rotateX: 0, rotateY: 0, filter: 'blur(0px)', stagger: 0.05, duration: 1.4, ease: 'back.out(1.8)', delay: 0.3 }
            );

            gsap.fromTo('#rsvp-success-screen div[class*="from-[#1d1a12]"]',
              { opacity: 0, scale: 0.7 },
              { opacity: 0.6, scale: 1.3, duration: 1.6, ease: 'power3.out' }
            );
          } else {
            gsap.fromTo('.success-char', 
              { opacity: 0, y: 25, scale: 0.8 },
              { opacity: 1, y: 0, scale: 1, stagger: 0.03, duration: 1.0, ease: 'power3.out', delay: 0.3 }
            );
          }

          gsap.fromTo('#success-ring', 
            { scale: 0.5, rotate: -45, opacity: 0 },
            { scale: 1, rotate: 0, opacity: 1, delay: 0.1, duration: 0.8, ease: 'back.out(1.5)' }
          );
        }
      });

      successCloseBtn?.addEventListener('click', () => {
        closeModal();
        setTimeout(() => {
          if (successScreen) {
            successScreen.classList.add('pointer-events-none');
            successScreen.style.opacity = '0';
          }
        }, 500);
      });

      // --- COUNTDOWN REAL-TIME LOGIC ---
      const targetDate = new Date(2026, 11, 25, 20, 0, 0).getTime();
      
      const updateCountdown = () => {
        const now = new Date().getTime();
        const diff = targetDate - now;
        
        if (diff < 0) {
          const dEl = document.getElementById('days');
          const hEl = document.getElementById('hours');
          const mEl = document.getElementById('minutes');
          const sEl = document.getElementById('seconds');
          if (dEl) dEl.innerText = "00";
          if (hEl) hEl.innerText = "00";
          if (mEl) mEl.innerText = "00";
          if (sEl) sEl.innerText = "00";
          return;
        }
        
        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);
        
        const dEl = document.getElementById('days');
        const hEl = document.getElementById('hours');
        const mEl = document.getElementById('minutes');
        const sEl = document.getElementById('seconds');

        if (dEl) dEl.innerText = String(days).padStart(2, '0');
        if (hEl) hEl.innerText = String(hours).padStart(2, '0');
        if (mEl) mEl.innerText = String(minutes).padStart(2, '0');
        if (sEl) sEl.innerText = String(seconds).padStart(2, '0');
      };
      
      setInterval(updateCountdown, 1000);
      updateCountdown();

      // Recalculate ScrollTriggers on window load
      window.addEventListener('load', () => {
        ScrollTrigger.refresh();
        registerHoverEvents();
      });
    </script>
  </body>
</html>
