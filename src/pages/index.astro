---
// src/pages/index.astro
import '../styles/global.css';
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gala de Cumpleaños - Invitación Privada</title>
    
    <!-- Premium Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700&family=JetBrains+Mono:wght@100;200;300;400&display=swap" rel="stylesheet">
    
    <!-- Lenis Smooth Scroll CDN -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
    
    <style>
      /* Clean, modern styling without redundant textures */
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: #070707;
      }
      ::-webkit-scrollbar-thumb {
        background: #c5a059;
        border-radius: 3px;
      }
      html, body {
        margin: 0;
        padding: 0;
        background-color: #070707;
        scroll-behavior: smooth;
        overflow-x: hidden;
      }
      
      /* Desktop cursor override */
      @media (min-width: 1024px) {
        body, a, button, [role="button"], input, select, textarea {
          cursor: none !important;
        }
      }

      /* Text Masking for slide-up reveal */
      .reveal-wrapper {
        position: relative;
        overflow: hidden;
        display: inline-block;
      }

      /* Lock scroll for envelope intro */
      body.locked-scroll {
        overflow: hidden !important;
        height: 100svh;
      }

      /* Smooth transition for maps container */
      .map-wrapper iframe {
        transition: filter 0.5s ease;
      }
      .map-wrapper:hover iframe {
        filter: grayscale(0.5) invert(0) contrast(1) brightness(1) !important;
      }
    </style>
  </head>
  <body class="bg-[#070707] text-[#faf9f6] font-['Plus_Jakarta_Sans'] antialiased select-none locked-scroll">
    
    <!-- Custom GSAP Interactive Cursor -->
    <div id="custom-cursor" class="hidden lg:block fixed top-0 left-0 w-8 h-8 border border-[#c5a059] rounded-full pointer-events-none z-[100] mix-blend-difference will-change-transform"></div>
    <div id="custom-cursor-dot" class="hidden lg:block fixed top-0 left-0 w-2 h-2 bg-[#c5a059] rounded-full pointer-events-none z-[100] will-change-transform"></div>

    <!-- PHYSICAL 3D ENVELOPE INTRO OVERLAY -->
    <div id="envelope-overlay" class="fixed inset-0 bg-[#070707] z-50 flex items-center justify-center p-4 overflow-hidden">
      <!-- Golden backdrop glow -->
      <div class="absolute w-[500px] h-[500px] bg-[#c5a059]/5 blur-[150px] rounded-full pointer-events-none"></div>
      
      <!-- 3D Envelope Container -->
      <div id="envelope-container" class="relative w-full max-w-[460px] aspect-[1.5/1]" style="perspective: 1500px;">
        <div id="envelope" class="w-full h-full relative" style="transform-style: preserve-3d; transform: rotateX(15deg) rotateY(-10deg);">
          
          <!-- Backside cover -->
          <div class="absolute inset-0 bg-[#0f0f0f] border border-[#c5a059]/15 rounded-2xl shadow-[0_30px_80px_rgba(0,0,0,0.95)]" style="transform: translateZ(-5px); transform-style: preserve-3d;">
            <!-- Cleaned: Texture gradients removed for a ultra-premium solid look -->
            <div class="absolute inset-0 bg-[#0c0c0c] rounded-2xl"></div>
          </div>

          <!-- THE PHYSICAL LETTER -->
          <div id="envelope-letter" class="absolute top-[8%] left-[6%] w-[88%] h-[84%] bg-[#121212] border border-[#c5a059]/20 rounded-xl p-6 flex flex-col justify-between text-center shadow-2xl" style="transform: translateZ(-2px); z-index: 1;">
            <div class="w-10 h-[1px] bg-[#c5a059]/30 self-center"></div>
            
            <div class="space-y-3">
              <span class="font-['Cormorant_Garamond'] text-[#c5a059] text-[10px] uppercase tracking-[0.5em] font-light">Invitación Privada</span>
              <h3 class="font-['Cormorant_Garamond'] text-2xl md:text-3xl text-white font-extralight tracking-wide leading-tight">Gala de Cumpleaños</h3>
              <p class="text-[9px] uppercase tracking-[0.3em] text-[#666] font-light">Especialmente para ti</p>
            </div>

            <div class="text-[9px] text-[#c5a059]/60 tracking-[0.2em] uppercase font-light">Abriendo...</div>
          </div>

          <!-- ENVELOPE FLAPS -->
          <div class="absolute inset-0 bg-[#111111]" style="clip-path: polygon(0 0, 52% 50%, 0 100%); transform: translateZ(5px); border-left: 1px solid rgba(197, 160, 89, 0.08);"></div>
          <div class="absolute inset-0 bg-[#111111]" style="clip-path: polygon(100% 0, 48% 50%, 100% 100%); transform: translateZ(5px); border-right: 1px solid rgba(197, 160, 89, 0.08);"></div>
          <div class="absolute inset-0 bg-[#151515]" style="clip-path: polygon(0 100%, 50% 48%, 100% 100%); transform: translateZ(10px); border-bottom: 1px solid rgba(197, 160, 89, 0.12);"></div>
          <div id="envelope-top-flap" class="absolute inset-0 bg-[#191919] origin-top" style="clip-path: polygon(0 0, 50% 52%, 100% 0); transform: translateZ(12px) rotateX(0deg); border-top: 1px solid rgba(197, 160, 89, 0.25);"></div>

          <!-- WAX SEAL BUTTON -->
          <div id="wax-seal-wrapper" class="absolute top-[48%] left-[50%] -translate-x-1/2 -translate-y-1/2 z-[25]" style="transform: translateZ(15px);">
            <button id="open-envelope-btn" class="group relative w-14 h-14 bg-[#c5a059] hover:bg-[#b59049] rounded-full flex items-center justify-center shadow-[0_8px_20px_rgba(0,0,0,0.6)] cursor-none transition-all duration-300 transform active:scale-95">
              <span class="font-['Cormorant_Garamond'] text-[#0a0a0a] text-lg font-bold tracking-tighter">GC</span>
              <span class="absolute inset-0 rounded-full border border-[#c5a059] animate-ping opacity-25 pointer-events-none"></span>
            </button>
          </div>

        </div>
      </div>
    </div>

    <!-- Scroll Progress Bar -->
    <div class="fixed top-0 left-0 w-full h-[3px] bg-[#161616] z-40">
      <div id="scroll-progress" class="h-full w-0 bg-[#c5a059] shadow-[0_0_8px_#c5a059]"></div>
    </div>

    <!-- Background Music Audio Tag -->
    <audio id="bg-music" src="/music/cancion.mp3" loop preload="auto"></audio>

    <!-- Hardware Accelerated Canvas Particle System (Sustituye partículas DOM para 100% fluidez) -->
    <canvas id="particle-canvas" class="fixed inset-0 w-full h-full pointer-events-none z-[1]"></canvas>

    <!-- Background Ambience Gradients (Totalmente Limpios sin texturas) -->
    <div class="fixed inset-0 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-[#17150f] via-[#070707] to-[#070707] pointer-events-none z-0"></div>

    <!-- MAIN VERTICAL NATIVE FLOW -->
    <div class="w-full relative z-10">

      <!-- HERO SECTION -->
      <section class="relative h-[100svh] w-full flex flex-col items-center justify-center overflow-hidden px-6">
        <!-- Clean: Grid overlay removed for clean visuals -->
        <div class="text-center relative max-w-5xl z-10">
          <div class="reveal-wrapper mb-6">
            <h2 class="hero-reveal text-xs md:text-sm uppercase tracking-[0.5em] text-[#c5a059] font-light translate-y-[100%]">
              Estás Invitado a Mi Celebración
            </h2>
          </div>
          
          <h1 class="font-['Cormorant_Garamond'] text-6xl md:text-9xl lg:text-[10rem] font-extralight tracking-tight leading-[0.9] mb-12">
            <span class="reveal-wrapper">
              <span class="hero-reveal inline-block translate-y-[100%] font-light">Mi Gala de</span>
            </span>
            <br/>
            <span class="reveal-wrapper">
              <span class="hero-reveal inline-block translate-y-[100%] italic text-[#c5a059] font-light">Cumpleaños</span>
            </span>
          </h1>

          <div class="block mb-12">
            <div class="reveal-wrapper">
              <!-- Removed Redundant Date (25.12.26) for clean experience -->
              <p class="hero-reveal text-base md:text-xl font-extralight tracking-[0.3em] text-[#a3a3a3] translate-y-[100%]">
                PALACIO DE CRISTAL &mdash; EXCLUSIVA INVITACIÓN DE GALA
              </p>
            </div>
          </div>

          <div class="reveal-wrapper">
            <div class="hero-reveal translate-y-[120%] flex flex-col items-center gap-3">
              <span class="text-xs uppercase tracking-widest text-[#555] animate-[bounce_2s_infinite]">Deslizar para comenzar el viaje</span>
              <svg class="w-5 h-5 text-[#c5a059] opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
              </svg>
            </div>
          </div>
        </div>
      </section>

      <!-- DETAILS SECTION: CRONOGRAMA INTERACTIVO DE GALA -->
      <section id="details" class="py-32 px-6 md:px-12 max-w-5xl mx-auto border-t border-[#1a1a1a] relative z-20">
        <div class="text-center max-w-2xl mx-auto mb-20">
          <span class="text-xs uppercase tracking-widest text-[#c5a059] font-light">El Itinerario</span>
          <h3 class="text-4xl md:text-6xl font-['Cormorant_Garamond'] font-light mt-3 leading-none">Cronograma de la Gala</h3>
          <p class="text-[#888] font-light mt-4 text-xs md:text-sm">Explora las fases de la noche. Haz clic en cada evento para revelar sus detalles.</p>
        </div>

        <!-- Interactive Schedule Timeline Accordion -->
        <div class="space-y-4 max-w-3xl mx-auto">
          
          <!-- Phase 1 -->
          <div class="timeline-item group bg-[#111]/80 border border-[#222] hover:border-[#c5a059]/40 rounded-2xl overflow-hidden transition-all duration-300">
            <button class="timeline-header w-full flex items-center justify-between p-6 text-left cursor-none focus:outline-none select-none">
              <div class="flex items-center gap-6">
                <span class="font-['JetBrains_Mono'] text-lg md:text-xl text-[#c5a059]">20:00 HRS</span>
                <span class="text-lg md:text-xl font-light text-white group-hover:text-[#c5a059] transition-colors duration-300">Coctel de Bienvenida</span>
              </div>
              <div class="timeline-icon text-[#c5a059] transform transition-transform duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
            </button>
            <div class="timeline-content h-0 opacity-0 overflow-hidden transition-all duration-500 ease-in-out px-6">
              <div class="pb-6 text-[#a3a3a3] font-light leading-relaxed text-sm md:text-base flex flex-col md:flex-row gap-6 items-center">
                <p class="flex-1">
                  Iniciamos la velada con una recepción privada en los jardines exteriores del palacio. Disfruta de una fina barra de mixología de autor diseñada especialmente para la ocasión, acompañada por un ensamble de jazz en vivo que ambientará la llegada de nuestros distinguidos invitados.
                </p>
                <div class="w-full md:w-48 aspect-[16/9] rounded-xl overflow-hidden bg-[#222]">
                  <img src="/images/champagne_cheers.png" alt="Brindis" class="w-full h-full object-cover" />
                </div>
              </div>
            </div>
          </div>

          <!-- Phase 2 -->
          <div class="timeline-item group bg-[#111]/80 border border-[#222] hover:border-[#c5a059]/40 rounded-2xl overflow-hidden transition-all duration-300">
            <button class="timeline-header w-full flex items-center justify-between p-6 text-left cursor-none focus:outline-none select-none">
              <div class="flex items-center gap-6">
                <span class="font-['JetBrains_Mono'] text-lg md:text-xl text-[#c5a059]">21:30 HRS</span>
                <span class="text-lg md:text-xl font-light text-white group-hover:text-[#c5a059] transition-colors duration-300">Cena de Honor</span>
              </div>
              <div class="timeline-icon text-[#c5a059] transform transition-transform duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
            </button>
            <div class="timeline-content h-0 opacity-0 overflow-hidden transition-all duration-500 ease-in-out px-6">
              <div class="pb-6 text-[#a3a3a3] font-light leading-relaxed text-sm md:text-base flex flex-col md:flex-row gap-6 items-center">
                <p class="flex-1">
                  Pasamos al Gran Salón Imperial para degustar una cena exclusiva de cuatro tiempos diseñada por el Chef Ejecutivo. Un viaje gastronómico maridado con vinos de reserva selectos, en una atmósfera deslumbrante rodeada de vitrales y candelabros históricos.
                </p>
                <div class="w-full md:w-48 aspect-[16/9] rounded-xl overflow-hidden bg-[#222]">
                  <img src="/images/gala_palace.png" alt="Gran Salón" class="w-full h-full object-cover" />
                </div>
              </div>
            </div>
          </div>

          <!-- Phase 3 -->
          <div class="timeline-item group bg-[#111]/80 border border-[#222] hover:border-[#c5a059]/40 rounded-2xl overflow-hidden transition-all duration-300">
            <button class="timeline-header w-full flex items-center justify-between p-6 text-left cursor-none focus:outline-none select-none">
              <div class="flex items-center gap-6">
                <span class="font-['JetBrains_Mono'] text-lg md:text-xl text-[#c5a059]">23:00 HRS</span>
                <span class="text-lg md:text-xl font-light text-white group-hover:text-[#c5a059] transition-colors duration-300">El Brindis & Semblanza</span>
              </div>
              <div class="timeline-icon text-[#c5a059] transform transition-transform duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
            </button>
            <div class="timeline-content h-0 opacity-0 overflow-hidden transition-all duration-500 ease-in-out px-6">
              <div class="pb-6 text-[#a3a3a3] font-light leading-relaxed text-sm md:text-base flex flex-col md:flex-row gap-6 items-center">
                <p class="flex-1">
                  Un momento íntimo de agradecimiento. Brindamos con Champagne por los años de vida, la amistad, y las memorias compartidas, acompañado de una proyección audiovisual muy especial conmemorando las experiencias más significativas vividas al lado de ustedes.
                </p>
                <div class="w-full md:w-48 aspect-[16/9] rounded-xl overflow-hidden bg-[#222]">
                  <img src="/images/champagne_cheers.png" alt="Brindis Copa" class="w-full h-full object-cover" />
                </div>
              </div>
            </div>
          </div>

          <!-- Phase 4 -->
          <div class="timeline-item group bg-[#111]/80 border border-[#222] hover:border-[#c5a059]/40 rounded-2xl overflow-hidden transition-all duration-300">
            <button class="timeline-header w-full flex items-center justify-between p-6 text-left cursor-none focus:outline-none select-none">
              <div class="flex items-center gap-6">
                <span class="font-['JetBrains_Mono'] text-lg md:text-xl text-[#c5a059]">23:30 HRS</span>
                <span class="text-lg md:text-xl font-light text-white group-hover:text-[#c5a059] transition-colors duration-300">Opening de la Pista & Fiesta</span>
              </div>
              <div class="timeline-icon text-[#c5a059] transform transition-transform duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
            </button>
            <div class="timeline-content h-0 opacity-0 overflow-hidden transition-all duration-500 ease-in-out px-6">
              <div class="pb-6 text-[#a3a3a3] font-light leading-relaxed text-sm md:text-base flex flex-col md:flex-row gap-6 items-center">
                <p class="flex-1">
                  La celebración de la vida alcanza su punto máximo. El DJ oficial enciende la pista de baile con una selección musical de primer nivel, acompañada de un show de luces arquitectónicas, barra libre de coctelería internacional y sorpresas a medianoche.
                </p>
                <div class="w-full md:w-48 aspect-[16/9] rounded-xl overflow-hidden bg-[#222]">
                  <img src="https://images.unsplash.com/photo-1481162854517-d9e353af153d?q=80&w=600&auto=format&fit=crop" alt="Fiesta" class="w-full h-full object-cover" />
                </div>
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- INTERACTIVE DRESS CODE SECTION (EXPERT IMMERSIVE SCALE-ON-SCROLL) -->
      <section id="dresscode" class="w-full h-screen bg-[#070707] relative z-20 overflow-hidden border-t border-[#1a1a1a] flex items-center justify-center">
        <div id="dresscode-pin-container" class="w-full h-full relative flex items-center justify-center overflow-hidden">
          
          <!-- Immersive Video Window -->
          <div id="dresscode-immersive-video" class="absolute inset-0 w-full h-full bg-[#111] overflow-hidden transform-gpu z-10">
            <!-- Video Damas (Visible by default) -->
            <video id="video-damas" src="/videos/damas.mp4" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-700 opacity-100 z-10" autoplay loop muted playsinline></video>
            
            <!-- Video Caballeros (Hidden by default) -->
            <video id="video-caballeros" src="/videos/caballeros.mp4" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-700 opacity-0 z-0" autoplay loop muted playsinline></video>
            
            <!-- Elegant glass/dark overlay shading for ultra-premium readability (Backdrop darkened slightly for maximum direct text legibility) -->
            <div class="absolute inset-0 bg-black/65 z-20 pointer-events-none"></div>
          </div>

          <!-- Centered Dress Code Typography Overlay (Slides up once video goes full screen) - NO BACKGROUND OR CARD BOX -->
          <div id="dresscode-details-card" class="absolute inset-0 z-30 flex items-center justify-center text-center p-6 opacity-0 pointer-events-none transform-gpu translate-y-12">
            <div class="relative w-full max-w-3xl min-h-[220px] flex items-center justify-center">
              
              <!-- Content Damas (Visible initially) -->
              <div id="content-damas" class="space-y-4 transform-gpu w-full">
                <span class="text-xs uppercase tracking-[0.4em] text-[#c5a059] font-light block mb-2">Etiqueta Requerida</span>
                <h3 class="font-['Cormorant_Garamond'] text-4xl md:text-6xl lg:text-7xl font-light text-white tracking-wide leading-none select-none">
                  Código de Vestimenta: Damas
                </h3>
                <p class="text-xs md:text-sm lg:text-base font-light text-[#faf9f6] max-w-xl mx-auto leading-relaxed mt-4">
                  Se requiere <strong class="font-semibold text-[#c5a059]">vestido largo formal</strong> que llegue hasta el suelo.
                  <br/>
                  Colores sugeridos: Negro, azul noche, verde esmeralda, vino o metalizados.
                  <br/>
                  <span class="text-red-300 font-semibold tracking-wide block mt-2">&bull; Agradecemos evitar vestir de color blanco, marfil o perla. &bull;</span>
                </p>
              </div>

              <!-- Content Caballeros (Positioned absolute for perfect overlap crossfade) -->
              <div id="content-caballeros" class="space-y-4 absolute inset-0 opacity-0 transform-gpu translate-y-8 w-full flex flex-col justify-center">
                <span class="text-xs uppercase tracking-[0.4em] text-[#c5a059] font-light block mb-2">Etiqueta Requerida</span>
                <h3 class="font-['Cormorant_Garamond'] text-4xl md:text-6xl lg:text-7xl font-light text-white tracking-wide leading-none select-none">
                  Código de Vestimenta: Caballeros
                </h3>
                <p class="text-xs md:text-sm lg:text-base font-light text-[#faf9f6] max-w-xl mx-auto leading-relaxed mt-4">
                  Se requiere <strong class="font-semibold text-[#c5a059]">esmoquin clásico negro</strong>, camisa de etiqueta blanca y moño de seda negra (evitar corbata).
                  <br/>
                  Alternativa: Traje formal oscuro de excelente corte impecable.
                  <br/>
                  <span class="text-[#c5a059] font-medium block mt-2">&bull; Calzado: Zapatos de vestir negros (charol o pulido fino). &bull;</span>
                </p>
              </div>

            </div>
          </div>
          
        </div>
      </section>

      <!-- LOCATION SECTION: ADDRESS & DARK INTERACTIVE GOOGLE MAPS -->
      <section id="location" class="py-24 px-6 md:px-12 max-w-5xl mx-auto border-t border-[#1a1a1a] relative z-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          
          <!-- Left: Location Details -->
          <div class="space-y-8">
            <span class="text-xs uppercase tracking-[0.4em] text-[#c5a059] font-light">El Santuario</span>
            <h3 class="text-4xl md:text-6xl font-['Cormorant_Garamond'] font-light leading-tight">El Palacio de Cristal</h3>
            
            <div class="space-y-4">
              <p class="text-[#a3a3a3] font-light leading-relaxed text-base md:text-lg">
                El Salón Imperial del Palacio de Cristal nos recibirá con su inigualable arquitectura de techos abovedados y vitrales históricos.
                <br/><br/>
                Av. Campos Elíseos 450, Polanco V Secc, Miguel Hidalgo, 11560 Ciudad de México, CDMX.
              </p>
              
              <div class="p-4 bg-[#111]/80 border border-[#222] rounded-xl text-xs text-[#666] font-light leading-relaxed">
                El recinto cuenta con servicio exclusivo de Valet Parking y estricta seguridad privada en el acceso. Se requerirá invitación digital (esta página) o nombre en lista en la recepción.
              </div>
            </div>

            <!-- Fully Interactive maps utility link -->
            <a href="https://maps.app.goo.gl/9Z4jT3yJqf77gP6x8" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 px-6 py-3.5 bg-transparent border border-[#c5a059]/40 hover:border-[#c5a059] text-[#c5a059] rounded-xl text-xs uppercase tracking-widest font-semibold transition-all duration-300 hover:bg-[#c5a059]/5 cursor-none">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="10" r="3"></circle><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z"></path></svg>
              Abrir en Google Maps GPS
            </a>
          </div>

          <!-- Right: Breathtaking customized Dark-Mode Google Maps Iframe (100% interactivo) -->
          <div class="relative w-full aspect-square md:aspect-[1.2/1] rounded-3xl overflow-hidden border border-[#222]/80 shadow-[0_20px_50px_rgba(0,0,0,0.6)] bg-[#070707] map-wrapper">
            <iframe 
